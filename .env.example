# Public environment variables (safe to commit)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENVIRONMENT=development

# Supabase (public keys can be exposed)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Stripe (publishable key is public)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key_here
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# Secret environment variables (DO NOT commit .env.local)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here

# Stripe
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Shopify
SHOPIFY_ADMIN_API_TOKEN=your_shopify_admin_token_here
SHOPIFY_SHOP_NAME=your_shop_name_here
SHOPIFY_API_VERSION=2024-01
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_token_here

# Redis (Upstash)
REDIS_URL=redis://your_redis_url_here
REDIS_SECRET=your_redis_secret_here

# Email Services
SENDGRID_API_KEY=your_sendgrid_api_key_here
RESEND_API_KEY=your_resend_api_key_here

# Claude API (for AI features)
ANTHROPIC_API_KEY=your_claude_api_key_here

# Google Places API (for address autocomplete)
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# OAuth Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
APPLE_CLIENT_ID=your_apple_client_id_here
APPLE_CLIENT_SECRET=your_apple_client_secret_here

# Sentry
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here

# Admin settings
ADMIN_EMAIL_WHITELIST=admin@hexdiva.com,admin2@hexdiva.com

# Feature flags
ENABLE_B2B_TIER=true
ENABLE_REFERRAL_SYSTEM=true
ENABLE_AI_RECOMMENDATIONS=true
ENABLE_REVIEWS=false
ENABLE_WISHLIST=true

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Shopify Webhook Secret
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_secret_here
