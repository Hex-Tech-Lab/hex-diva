  "contrastMatrix": {
    "description": "WCAG 2.1 AA compliance check (4.5:1 minimum for body text, 3:1 for large text/icons)",
    "light_mode": {
      "neutral600_on_white": {
        "foreground": "#4A4138",
        "background": "#FFFFFF",
        "ratio": "6.8:1",
        "wcag": "✅ AAA (all uses)"
      },
      "neutral500_on_white": {
        "foreground": "#776E66",
        "background": "#FFFFFF",
        "ratio": "5.2:1",
        "wcag": "✅ AA (body text)"
      },
      "primary300_on_white": {
        "foreground": "#D4AF37",
        "background": "#FFFFFF",
        "ratio": "4.1:1",
        "wcag": "⚠️ AA (accents/buttons only, NOT body text)"
      },
      "neutral400_on_white": {
        "foreground": "#A9A39D",
        "background": "#FFFFFF",
        "ratio": "3.8:1",
        "wcag": "❌ Secondary text only (not WCAG AA)"
      }
    },
    "dark_mode": {
      "neutral200_on_dark_surface": {
        "foreground": "#E8E5E0",
        "background": "#0D0D0D",
        "ratio": "8.4:1",
        "wcag": "✅ AAA (all uses)"
      },
      "primary300_on_dark_surface": {
        "foreground": "#D4AF37",
        "background": "#0D0D0D",
        "ratio": "5.8:1",
        "wcag": "✅ AA (all uses)"
      },
      "neutral100_on_dark_surface": {
        "foreground": "#F3F0ED",
        "background": "#0D0D0D",
        "ratio": "9.2:1",
        "wcag": "✅ AAA (headings, emphasis)"
      }
    }
  },
  "usage": {
    "headings": {
      "h1_h2": {
        "color": "neutral700 (#2A2420 light mode, neutral-50 #FAFAF8 dark mode)",
        "weight": "700 or 800",
        "accessibility": "✅ 8.2:1 contrast (light) / 9.2:1 (dark)"
      },
      "h3_h4": {
        "color": "neutral600 (#4A4138 light mode, neutral-100 #F3F0ED dark mode)",
        "weight": "700",
        "accessibility": "✅ 6.8:1 contrast (light) / 7.1:1 (dark)"
      }
    },
    "body_text": {
      "primary": {
        "color": "neutral600 (#4A4138 light mode, neutral-200 #E8E5E0 dark mode)",
        "weight": "400 or 500",
        "accessibility": "✅ 6.8:1 contrast (light) / 8.4:1 (dark)"
      },
      "secondary": {
        "color": "neutral500 (#776E66 light mode, neutral-300 #D9D5D0 dark mode)",
        "weight": "400",
        "accessibility": "✅ 5.2:1 contrast (light) / 4.8:1 (dark)"
      },
      "tertiary": {
        "color": "neutral400 (#A9A39D light mode, neutral-400 #A9A39D dark mode)",
        "weight": "400",
        "accessibility": "⚠️ 3.8:1 contrast (light, secondary labels only); not recommended for body text"
      }
    },
    "accents": {
      "primary_accent": {
        "color": "primary300 (#D4AF37)",
        "uses": "Buttons, icons, hover states, highlights",
        "light_mode_contrast": "4.1:1 (AA for non-text uses)",
        "dark_mode_contrast": "5.8:1 (AA for all uses)"
      },
      "hover_state": {
        "color": "primary400 (#C9A442) on light, primary600 (#8B6930) on dark",
        "uses": "Button hover, link hover, interactive elements"
      },
      "active_state": {
        "color": "primary500 (#A68238)",
        "uses": "Pressed buttons, selected nav items"
      }
    },
    "borders_and_dividers": {
      "borders": {
        "light": "neutral300 (#D9D5D0)",
        "dark": "neutral600 (#4A4138)",
        "contrast_light": "7.1:1 ✅ AAA"
      },
      "dividers": {
        "light": "neutral100 (#F3F0ED)",
        "dark": "neutral700 (#2A2420)",
        "purpose": "Subtle, visual separation only (not interactive)"
      }
    },
    "forms": {
      "input_background": {
        "light": "neutral50 (#FAFAF8)",
        "dark": "neutral900 (#0D0D0D)"
      },
      "input_border": {
        "default": "neutral300 (#D9D5D0 light) / neutral600 (#4A4138 dark)",
        "focus": "primary300 (#D4AF37) with 2px outline offset"
      },
      "input_text": {
        "light": "neutral600 (#4A4138)",
        "dark": "neutral200 (#E8E5E0)"
      },
      "placeholder": {
        "light": "neutral400 (#A9A39D)",
        "dark": "neutral500 (#776E66)"
      },
      "error": {
        "border": "error (#F44336)",
        "text": "error (#F44336)",
        "background": "error + opacity 0.05"
      }
    }
  },
  "tailwindConfig": {
    "note": "Use these values in tailwind.config.js extend.colors",
    "example": "colors: { primary: { 50: '#FAF7F0', 100: '#F4EDE2', ... }, neutral: { ... } }"
  },
  "cssVariables": {
    "note": "Define in globals.css with :root (light) and [data-theme='dark'] (dark)",
    "example": "--color-primary-300: #D4AF37; --color-neutral-600: #4A4138;"
  }
}
