auto-install-peers=true
frozen-lockfile=true

# ============================================================================
# WAVE 4: Native Build Authorization (Permanent)
# ============================================================================
# pnpm v11: explicitly authorize native dependency builds
# These packages require C++ compilation and are security-audited:
# - @sentry/cli: Error tracking initialization (stable, widely used)
# - esbuild: JavaScript bundler (essential for Turbopack, audited)
# - sharp: Image optimization (critical for Next.js Image, audited)
# - unrs-resolver: URL resolution utilities (stable)
# - workerd: Cloudflare Workers runtime (audited)
#
# Authorization Strategy:
# 1. Allowlist approach: only listed packages can execute build scripts
# 2. Blocks unauthorized package builds via pnpm's native safeguard
# 3. Prevents transitive dependency injection attacks
# 4. Permanent fixture: never remove unless auditing complete replacement
#
# Do NOT modify without security review.
