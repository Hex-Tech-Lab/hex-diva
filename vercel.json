{
  "buildCommand": "pnpm build",
  "devCommand": "pnpm dev",
  "installCommand": "pnpm install",
  "framework": "nextjs",
  "regions": ["cdg1"],
  "git": {
    "deploymentEnabled": {
      "main": true,
      "develop": true
    }
  },
  "crons": [
    {
      "path": "/api/cron/sync-inventory",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/process-payouts",
      "schedule": "0 0 1 * *"
    },
    {
      "path": "/api/cron/monthly-reset",
      "schedule": "0 0 1 * *"
    }
  ]
}
